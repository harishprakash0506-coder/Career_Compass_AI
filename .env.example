# ─── Flask Core ───────────────────────────────────────────────────────────────
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=change-this-to-a-random-64-char-string-before-deploying

# ─── Database ──────────────────────────────────────────────────────────────────
# Development (SQLite — path relative to project root)
DEV_DATABASE_URL=sqlite:///instance/careercompass_dev.db

# Production (SQLite — swap for PostgreSQL URI in production)
DATABASE_URL=sqlite:///instance/careercompass.db

# ─── Upload Limits ─────────────────────────────────────────────────────────────
# Max file upload size in bytes (default: 16 MB)
MAX_CONTENT_LENGTH=16777216

# ─── Application Port ──────────────────────────────────────────────────────────
PORT=5000
